{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawLaunch",
  "version": "0.1.0",
  "identifier": "ai.clawlaunch",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClawLaunch",
        "width": 1200,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../scripts/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Easy one-click ClawBot installer and launcher",
    "longDescription": "ClawLaunch lets you install and run ClawBot on your computer without using the terminal. Just enter your API keys, pick a profile, and click Install."
  }
}
